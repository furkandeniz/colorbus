; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are meant to be edited
; using the specific UI menu that provides errors and
; formatting for their values.

config_version=5

[application]

config/name="Color Bus"
run/main_scene="res://scenes/app/main.tscn"
config/features=PackedStringArray("4.7", "Mobile")
boot_splash/bg_color=Color(0.09, 0.09, 0.11, 1)

[autoload]

PlatformService="*res://scripts/platform/platform_service.gd"
SaveManager="*res://scripts/data/save_manager.gd"
SettingsManager="*res://scripts/data/settings_manager.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
AppRouter="*res://scripts/core/app_router.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"
window/energy_saving/keep_screen_on=true

; Both emulation directions are intentionally OFF. Godot 4's Control/
; BaseButton system natively handles both InputEventMouseButton and
; InputEventScreenTouch without emulation. With both flags on, a single
; physical tap/click generates a real event *and* a synthesized companion
; event, and BaseButton reacts to both -- causing `pressed` to fire twice.
; Leaving both off means exactly one real event per interaction, mouse and
; touch handled identically, no double-firing.
[input_devices]

pointing/emulate_touch_from_mouse=false
pointing/emulate_mouse_from_touch=false

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
textures/vram_compression/import_etc2_astc=true
